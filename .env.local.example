NEXT_PUBLIC_COS_PUBLIC_BASE_URL=https://portfolio-gaoxinming-1305428454.cos.ap-beijing.myqcloud.com

ADMIN_UPLOAD_TOKEN=

# 本地 dev 零 COS 外网下行：先 npm run dev:sync -- --media，再设为 1
DEV_USE_LOCAL_SNAPSHOT=1
